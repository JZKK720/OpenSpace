FROM node:20-bookworm-slim AS builder

WORKDIR /app

COPY showcase/my-daily-monitor/package.json showcase/my-daily-monitor/package-lock.json ./
RUN npm ci

COPY showcase/my-daily-monitor/ ./
RUN npm run build


FROM node:20-bookworm-slim AS runtime

ENV NODE_ENV=production \
    PORT=5173

WORKDIR /app

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/server-dist ./server-dist
COPY openspace/config/external_agents.json ./openspace/config/external_agents.json

EXPOSE 5173

CMD ["node", "server-dist/server/index.js"]