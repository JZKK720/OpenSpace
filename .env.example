# GHCR image defaults for pull-first releases.
# Set OPENSPACE_IMAGE_TAG to a release tag like v0.6.0 to pin a rollout.
# The same registry/tag pair also selects the mirrored GHCR base images used by -LocalBuild.
OPENSPACE_IMAGE_REGISTRY=ghcr.io/jzkk720
OPENSPACE_IMAGE_TAG=main

# Docker Compose defaults for the OpenSpace web surfaces

CUBECLOUD_PORT=7788
AGENTS_MONITOR_PORT=5173

# IronClaw browser-facing and container-facing URLs
IRONCLAW_PUBLIC_URL=http://127.0.0.1:3231/
IRONCLAW_INTERNAL_URL=http://host.docker.internal:3231/
IRONCLAW_HEALTH_URL=http://host.docker.internal:3231/
IRONCLAW_ACTION_URL=http://host.docker.internal:3231/api/chat/send

# Set one of these to the IronClaw gateway bearer token used by /api/chat/*.
IRONCLAW_AUTH_TOKEN=
GATEWAY_AUTH_TOKEN=

# Only set this if your IronClaw runtime exposes a real MCP endpoint.
IRONCLAW_MCP_URL=

# OpenClaw agent (openai-compat protocol, port 18788)
OPENCLAW_PUBLIC_URL=http://127.0.0.1:18788/
OPENCLAW_INTERNAL_URL=http://host.docker.internal:18788/
OPENCLAW_HEALTH_URL=http://host.docker.internal:18788/health
OPENCLAW_ACTION_URL=http://host.docker.internal:18788/v1/chat/completions
OPENCLAW_AUTH_TOKEN=

# Optional: if the OpenClaw gateway itself talks to host Ollama and host.docker.internal is unreliable,
# docker-up.ps1 can push this base URL into /home/node/.openclaw/openclaw.json and restart the gateway.
OPENCLAW_OLLAMA_BASE_URL=

# Hermes agent (OpenAI-compat protocol — stateless LLM gateway, port 8789)
HERMES_PUBLIC_URL=http://127.0.0.1:8789/
HERMES_INTERNAL_URL=http://host.docker.internal:8789/
HERMES_HEALTH_URL=http://host.docker.internal:8789/health
HERMES_ACTION_URL=http://host.docker.internal:8789/v1/chat/completions
HERMES_API_KEY=

# OpenHarness agent harness
# OPENHARNESS_PUBLIC_URL: browser-accessible URL (web UI or ttyd)
# OPENHARNESS_INTERNAL_URL: container-internal API endpoint
# OPENHARNESS_HEALTH_URL: health probe target
OPENHARNESS_PUBLIC_URL=http://localhost:8780
OPENHARNESS_INTERNAL_URL=http://host.docker.internal:8581
OPENHARNESS_HEALTH_URL=http://host.docker.internal:8581/health
