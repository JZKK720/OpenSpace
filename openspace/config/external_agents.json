{
  "version": 1,
  "mcp_servers": [
    {
      "id": "openspace-remote",
      "name": "OpenSpace Remote Runtime",
      "description": "Shared MCP runtime exposed by the companion OpenSpace remote agent container.",
      "server_name": "external-openspace-remote",
      "url_env": "OPENSPACE_REMOTE_MCP_URL",
      "health_url_env": "OPENSPACE_REMOTE_HEALTH_URL",
      "tags": ["mcp", "runtime", "openspace"]
    }
  ],
  "agents": [
    {
      "id": "ironclaw",
      "name": "IronClaw",
      "description": "Bearer-authenticated IronClaw runtime delegated through the gateway chat API.",
      "kind": "acting-agent",
      "protocol": "chat-thread",
      "capabilities": ["handoff", "history"],
      "handoff_mode": "chat_thread",
      "history_mode": "thread_history",
      "public_url_env": "IRONCLAW_PUBLIC_URL",
      "internal_url_env": "IRONCLAW_INTERNAL_URL",
      "health_url_env": "IRONCLAW_HEALTH_URL",
      "action_url_env": "IRONCLAW_ACTION_URL",
      "action_auth_token_env": "IRONCLAW_AUTH_TOKEN",
      "history_auth_token_env": "IRONCLAW_AUTH_TOKEN",
      "mcp_url_env": "IRONCLAW_MCP_URL",
      "mcp_auth_token_env": "IRONCLAW_AUTH_TOKEN",
      "linked_mcp_servers": ["openspace-remote"],
      "tags": ["assistant", "delegate", "ironclaw"]
    },
    {
      "id": "nanobot",
      "name": "Nanobot",
      "description": "MCP-based autonomous agent runtime. Chat with your local nanobot instance through a browser-friendly interface.",
      "kind": "acting-agent",
      "protocol": "nanobot-mcp",
      "capabilities": ["handoff", "history"],
      "handoff_mode": "chat_thread",
      "history_mode": "thread_history",
      "public_url_env": "NANOBOT_PUBLIC_URL",
      "internal_url_env": "NANOBOT_INTERNAL_URL",
      "health_url_env": "NANOBOT_HEALTH_URL",
      "action_url_env": "NANOBOT_ACTION_URL",
      "history_url_env": "NANOBOT_ACTION_URL",
      "tags": ["assistant", "delegate", "nanobot"]
    },
    {
      "id": "hermes",
      "name": "Hermes",
      "description": "OpenAI-compatible agent gateway. Delegates tasks via /v1/chat/completions.",
      "kind": "acting-agent",
      "protocol": "openai-compat",
      "capabilities": ["handoff"],
      "handoff_mode": "request_response",
      "public_url_env": "HERMES_PUBLIC_URL",
      "internal_url_env": "HERMES_INTERNAL_URL",
      "health_url_env": "HERMES_HEALTH_URL",
      "action_url_env": "HERMES_ACTION_URL",
      "action_auth_token_env": "HERMES_API_KEY",
      "model": "gemma4:e4b-it-q8_0",
      "tags": ["assistant", "delegate", "hermes"]
    }
  ]
}